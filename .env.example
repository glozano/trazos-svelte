# Brevo transactional email key
BREVO_API_KEY=your_brevo_api_key

# Contact form routing
CONTACT_TO_EMAIL=hello@trazos.club
CONTACT_FROM_EMAIL=no-reply@trazos.club
CONTACT_SENDER_NAME=Trazos Contact

# Cloudflare Turnstile (optional but recommended)
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Board memory / Mongo (used by server/index.js)
TRAZOS_MEMORY_ENABLED=true
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB_NAME=mongo_trazos
MONGO_LINES_COLLECTION=lines
TRAZOS_MEMORY_TTL_SECONDS=10800
TRAZOS_MEMORY_REPLAY_LIMIT=0

# Admin sessions
ADMIN_SESSION_TTL_SECONDS=86400

# GIF export / GIPHY upload
GIPHY_API_KEY=your_giphy_api_key
GIPHY_USERNAME=trazosclub
GIPHY_TAGS=trazos,trazosclub,processing,collaborative,drawing,draw
GIF_TEMP_DIR=static/user-img
GIF_MAX_BYTES=12582912
GIF_TEMP_TTL_SECONDS=1800
GIF_CLEANUP_INTERVAL_SECONDS=300
